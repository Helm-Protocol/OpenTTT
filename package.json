{
  "name": "openttt",
  "version": "0.2.6",
  "description": "OpenTTT — TLS-grade transaction ordering for DeFi. Time + Logic + Sync.",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Helm-Protocol/OpenTTT"
  },
  "keywords": [
    "mev",
    "defi",
    "ttt",
    "proof-of-time",
    "transaction-ordering",
    "grg",
    "base",
    "ethereum"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage --forceExit",
    "verify": "cd contracts && npx hardhat verify --network"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "ethers": "^6.10.0"
  },
  "peerDependencies": {
    "@privy-io/server-auth": "^1.32.5",
    "@turnkey/api-key-stamper": "^0.6.2",
    "@turnkey/ethers": "^1.3.25"
  },
  "peerDependenciesMeta": {
    "@privy-io/server-auth": {
      "optional": true
    },
    "@turnkey/api-key-stamper": {
      "optional": true
    },
    "@turnkey/ethers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "mcpName": "io.github.Helm-Protocol/openttt-pot"
}
